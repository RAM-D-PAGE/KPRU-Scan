{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/",
            "destination": "/static/index.html"
        },
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*).(css|js|png|jpg|ico)",
            "destination": "/static/$1.$2"
        }
    ]
}